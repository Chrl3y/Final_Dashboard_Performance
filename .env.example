# ─── Nova Dashboard — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# ── Metabase connection ────────────────────────────────────────────────────────
METABASE_URL=https://your-metabase-host:3000
METABASE_USERNAME=your@email.com
METABASE_PASSWORD=yourpassword
METABASE_SECRET=your_metabase_jwt_secret
METABASE_SITE_URL=https://your-metabase-host:3000
NOVA_DB_ID=2

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
CACHE_TTL=3600

# ── AI Insights (Claude API) ──────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
# IMPORTANT: Generate a NEW key — never paste keys into chat or emails
ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...
